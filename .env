# Environment
ENVIRONMENT=production
SECRET_KEY=your-super-secret-key-change-this-in-production
BASE_URL=https://yourdomain.uz

# Database
#POSTGRES_SERVER=postgres
#POSTGRES_USER=postgres
#POSTGRES_PASSWORD=0000
#POSTGRES_DB=school_db
DATABASE_URL=sqlite+aiosqlite:///./school.db
# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@yourdomain.uz
EMAILS_FROM_NAME="School Management System"

# Admin
FIRST_SUPERUSER_EMAIL=admin@yourdomain.uz
FIRST_SUPERUSER_PASSWORD=secure_admin_password_here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS
ALLOWED_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz