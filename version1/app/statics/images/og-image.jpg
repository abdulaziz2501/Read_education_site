<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
    <rect width="1200" height="630" fill="url(#gradient)"/>
    <text x="600" y="300" font-family="Arial" font-size="72" fill="white" text-anchor="middle" font-weight="bold">School of Excellence</text>
    <text x="600" y="380" font-family="Arial" font-size="36" fill="rgba(255,255,255,0.8)" text-anchor="middle">Quality Education for a Brighter Future</text>
    <circle cx="200" cy="500" r="50" fill="rgba(255,255,255,0.1)"/>
    <circle cx="1000" cy="150" r="80" fill="rgba(255,255,255,0.1)"/>
    <defs>
        <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#667eea"/>
            <stop offset="100%" stop-color="#764ba2"/>
        </linearGradient>
    </defs>
</svg>